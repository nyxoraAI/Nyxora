{
  "name": "nyxora-desktop",
  "version": "0.0.1-alpha.1",
  "private": true,
  "description": "Nyxora Desktop Application",
  "author": "Nyxora Protocol <ainyxor@gmail.com>",
  "homepage": "https://nyxoraai.github.io/Nyxora/",
  "main": "src/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder build --linux"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nyxora.desktop",
    "productName": "Nyxora",
    "electronVersion": "30.0.0",
    "npmRebuild": false,
    "icon": "build/icon.png",
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "viem": "^2.55.0"
  }
}
