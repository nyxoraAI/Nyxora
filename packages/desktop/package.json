{
  "name": "nyxora-desktop",
  "version": "0.0.1",
  "private": true,
  "author": {
    "name": "Nyxora Protocol",
    "email": "hello@nyxora.ai"
  },
  "description": "Nyxora Desktop Application",
  "homepage": "https://nyxoraai.github.io/Nyxora/",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "start": "electron . --no-sandbox",
    "prebuild": "npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.15",
    "electron": "latest",
    "electron-builder": "latest",
    "postcss": "^8.4.30",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.2",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.nyxora.desktop",
    "productName": "Nyxora Desktop",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}
