{
  "name": "nyxora",
  "version": "1.6.12",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "nyxora": "bin/nyxora.mjs"
  },
  "scripts": {
    "postinstall": "npm run build --workspace=dashboard || echo '⚠️ Build failed – dashboard UI may be missing'",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npx ts-node -T launcher.ts\" \"npm run dev --workspace=dashboard\"",
    "start": "node ./bin/nyxora.mjs start",
    "stop": "node ./bin/nyxora.mjs stop",
    "restart": "node ./bin/nyxora.mjs restart",
    "dashboard": "node ./bin/nyxora.mjs dashboard",
    "setup": "node ./bin/nyxora.mjs setup",
    "build": "npm run build --workspace=dashboard",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@napi-rs/keyring": "^1.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "open": "^11.0.0",
    "openai": "^6.39.0",
    "pdf-parse": "^2.4.5",
    "picocolors": "^1.1.1",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "viem": "^2.51.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.9.1",
    "vitepress": "^1.6.4"
  }
}
