{
  "name": "nyxora",
  "version": "26.6.20",
  "description": "Your Personal Web3 Assistant",
  "keywords": [
    "web3",
    "ai",
    "agent",
    "crypto",
    "mcp",
    "automation",
    "defi",
    "zero-trust"
  ],
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "bin",
    "dist",
    "launcher.ts",
    "packages/core/src",
    "packages/core/package.json",
    "packages/policy/src",
    "packages/policy/package.json",
    "packages/signer/src",
    "packages/signer/package.json",
    "packages/mcp-server/src",
    "packages/mcp-server/dist",
    "packages/mcp-server/package.json",
    "packages/dashboard/dist",
    "packages/dashboard/package.json"
  ],
  "bin": {
    "nyxora": "bin/nyxora.mjs"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"NODE_NO_WARNINGS=1 ./node_modules/.bin/ts-node -T launcher.ts\" \"npm run dev --workspace=nyxora-dashboard\"",
    "start": "node ./bin/nyxora.mjs start",
    "stop": "node ./bin/nyxora.mjs stop",
    "restart": "node ./bin/nyxora.mjs restart",
    "dashboard": "node ./bin/nyxora.mjs dashboard",
    "setup": "node ./bin/nyxora.mjs setup",
    "set-key": "node ./bin/nyxora.mjs set-key",
    "doctor": "node ./bin/nyxora.mjs doctor",
    "build": "tsc && npm run build --workspace=nyxora-mcp-server && npm run build --workspace=nyxora-dashboard",
    "test": "npm run test --workspace=packages/core"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@inquirer/search": "^4.2.1",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@napi-rs/keyring": "^1.3.0",
    "@notionhq/client": "^5.22.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "open": "^11.0.0",
    "openai": "^6.39.0",
    "pdf-parse": "^2.4.5",
    "picocolors": "^1.1.1",
    "playwright": "^1.60.0",
    "read-excel-file": "^9.2.0",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^6.0.3",
    "viem": "^2.51.0",
    "write-excel-file": "^4.1.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "shell-quote": "^1.8.3",
    "tar": "^7.4.3",
    "ws": "^8.21.0",
    "esbuild": "^0.28.0",
    "lodash": "^4.18.1",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.7",
    "undici": "^8.4.1",
    "uuid": "^14.0.0",
    "lodash-es": "^4.18.1",
    "elliptic": "^6.6.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "oxc-minify": "^0.135.0",
    "vitepress": "^2.0.0-alpha.17"
  }
}
